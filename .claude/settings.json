{
  "permissions": {
    "allow": [
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(bash .claude/hooks/scan_secrets.sh:*)",
      "Bash(ls:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/governance_shim.sh session_start",
            "timeout": 5,
            "statusMessage": "Initializing governance shim"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/governance_shim.sh pre_tool_use",
            "timeout": 3,
            "statusMessage": "Governance: logging tool invocation"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/governance_shim.sh subagent_stop",
            "timeout": 5,
            "statusMessage": "Governance: task checkpoint"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/anchored-prime.sh",
            "timeout": 10,
            "statusMessage": "Building anchored context summary"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_write_check.sh",
            "timeout": 15,
            "statusMessage": "Running post-write checks"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_write_check.sh",
            "timeout": 15,
            "statusMessage": "Running post-write checks"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/raelisavitt/distributional-agi-safety/.claude/metadata-updater.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/governance_shim.sh post_tool_use",
            "timeout": 3,
            "statusMessage": "Governance: logging tool outcome"
          }
        ]
      }
    ]
  }
}
